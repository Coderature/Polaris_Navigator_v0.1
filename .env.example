# ── 데이터 파이프라인 (서버 전용, scripts/ 에서 사용) ──────────────────────────

# DART 공시 API — https://opendart.fss.or.kr/ 에서 무료 발급
DART_API_KEY=

# 네이버 검색 API — https://developers.naver.com/ 에서 애플리케이션 등록 후 발급
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# Groq LLM API (리스크 추출용) — https://console.groq.com/ 에서 무료 발급
GROQ_API_KEY=

# ── 프론트엔드 (브라우저에서 사용, VITE_ 접두사 필수) ──────────────────────────

# Finnhub 주가 데이터 — https://finnhub.io/ 에서 무료 발급
VITE_FINNHUB_API_KEY=

# Groq (AI 요약 기능, 프론트엔드) — 위 GROQ_API_KEY와 동일한 키 사용 가능
VITE_GROQ_API_KEY=
